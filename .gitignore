# =============================================================================
# MidnightCEO .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem

# ---------------------------------------------------------------------------
# Node.js
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
.next/
out/

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------------
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
*.pid
*.seed
*.pid.lock
.cache/
tmp/
temp/
