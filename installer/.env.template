# =============================================================================
# MidnightCEO — Local Compute Mode Environment
#
# Generated by the MidnightCEO installer. Values stay on this machine and
# are never sent to MidnightCEO servers.
#
# DO NOT commit this file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Compute mode
# ---------------------------------------------------------------------------
COMPUTE_MODE=local
MACHINE_ID=__MACHINE_ID__
COMPANY_ID=__COMPANY_ID__
LOCAL_MACHINE_NAME=__LOCAL_MACHINE_NAME__

# ---------------------------------------------------------------------------
# Anthropic (LLM provider)
# ---------------------------------------------------------------------------
LLM_BACKEND=api
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__

# ---------------------------------------------------------------------------
# Supabase (database & auth — cloud)
# ---------------------------------------------------------------------------
SUPABASE_URL=__SUPABASE_URL__
SUPABASE_SERVICE_ROLE_KEY=__SUPABASE_SERVICE_ROLE_KEY__
SUPABASE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_URL=__SUPABASE_URL__
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Redis (local — provided by Docker Compose)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Console API (local)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# GitHub (optional — required for existing project mode)
# ---------------------------------------------------------------------------
# GITHUB_TOKEN=
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_ORG=

# ---------------------------------------------------------------------------
# OpenAI (optional — Whisper transcription & TTS)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# ElevenLabs (optional — speech synthesis)
# ---------------------------------------------------------------------------
# ELEVENLABS_API_KEY=
